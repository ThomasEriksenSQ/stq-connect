+              <p className="mt-0.5 text-[0.8125rem] text-muted-foreground break-all">
+                {entry.sender_email} → {entry.recipient_email}
+              </p>
+              <p className="mt-0.5 text-[0.75rem] text-muted-foreground">{entry.attachment_name}</p>
+            </div>
+            <span className="text-[0.8125rem] text-muted-foreground">
